PORT=3000
WIDGET_BASE_PATH=/
WIDGET_NAME=ark-widget
WIDGET_PROVIDER=ArkWidget
REQUIRE_AGENT_DESKTOP=true
LOG_LEVEL=INFO
POWERTOOLS_SERVICE_NAME=ark-wxcc-widget-host
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/server.log
ARIES_API_BASE_URL=https://wststint.aries.state.ar.us:7079
ARIES_API_UPLOAD_URL = https://wststint.aries.state.ar.us:7082
ARIES_API_KEY=replace-me
ARIES_API_TIMEOUT_MS=10000
ARIES_NEW_CALL_ENDPOINT=/contact-arrivals

# Legacy THIRD_PARTY_* names are still accepted by server/app.js,
# but new installs should use the ARIES_* names above.